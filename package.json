{
  "name": "accounting",
  "version": "1.0.0",
  "description": "Spaza Accounting - simple accounting for small business",
  "author": "Spaza",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "electron": "electron electron/main.js",
    "electron:dev": "concurrently \"expo start --web\" \"wait-on http://localhost:8081 && electron electron/main.js\"",
    "electron:build": "expo export -p web && electron-builder --dir",
    "electron:build:win": "expo export -p web && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.spaza.accounting",
    "productName": "Spaza Accounting",
    "extraMetadata": { "main": "electron/main.js" },
    "directories": { "output": "release" },
    "files": ["dist/**", "electron/**"],
    "win": {
      "target": ["nsis", "portable"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@gluestack-style/react": "^1.0.57",
    "@gluestack-ui/config": "^1.1.20",
    "@gluestack-ui/themed": "^1.1.73",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-aria/dialog": "^0.0.5",
    "@react-native-aria/focus": "^0.2.9",
    "@react-native-aria/interactions": "^0.2.16",
    "@react-native-aria/overlays": "^0.3.15",
    "@react-native-aria/utils": "^0.2.12",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "drizzle-orm": "^0.45.1",
    "expo": "~55.0.5",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.71.2",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.2.10",
    "babel-plugin-inline-import": "^3.0.0",
    "babel-preset-expo": "^55.0.10",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.9",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.9.2",
    "wait-on": "^8.0.1"
  }
}
